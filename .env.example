# Copy to .env (gitignored) and fill in. All optional — the app degrades gracefully without them.

# Pexels API key — free image source, used when Pinterest token is absent.
PEXELS_API_KEY=

# Pinterest official v5 API access token — reads the authenticated user's own Pins.
# Add once your Pinterest Developer app is approved. Never scrapes pinterest.com.
PINTEREST_ACCESS_TOKEN=

# Optional model overrides (defaults shown).
CLIP_MODEL=openai/clip-vit-base-patch32
CAPTION_MODEL=google/flan-t5-base
