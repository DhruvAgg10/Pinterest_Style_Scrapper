# Copy to .env (gitignored) and fill in. The app degrades gracefully if these are missing.

# Hugging Face token — powers image analysis (vision model) and caption generation.
# Create at huggingface.co -> Settings -> Access Tokens. Needs "Make calls to Inference Providers".
HF_TOKEN=

# Pexels API key — free image source, used when no Pinterest token is set.
PEXELS_API_KEY=

# Pinterest official v5 API access token — reads the authenticated user's own Pins.
# Add once your Pinterest Developer app is approved. Never scrapes pinterest.com.
PINTEREST_ACCESS_TOKEN=

# Optional model overrides (defaults shown).
VLM_MODEL=google/gemma-3-27b-it
CAPTION_MODEL=google/gemma-3-27b-it
